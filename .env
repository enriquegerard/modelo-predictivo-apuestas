# ===== Modo =====
# true => usa JSON local (data/mock_matches.json y data/mock_odds.json)
MOCK_MODE=false

# ===== APIs (opcional si MOCK_MODE=true) =====
FOOTBALL_DATA_API_KEY=
THE_ODDS_API_KEY=

# API base URLs
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
THE_ODDS_BASE_URL=https://api.the-odds-api.com

# Ligas y deportes (CSV)
LEAGUES=PL,PD,SA,BL1,FL1,DED,PPL,ELC,TUR,SPL,BEL,CL,EL,UECL,MLS,MX1,BSA,ARG
ODDS_SPORTS=soccer_epl,soccer_spain_la_liga,soccer_italy_serie_a

# Zona horaria y runtime
TIMEZONE=Europe/Madrid
REQUEST_TIMEOUT_SEC=15
MIN_REQUEST_INTERVAL_SEC=0.35
CACHE_TTL_MINUTES=15

# Base de datos local SQLite
DB_PATH=data/app.db
