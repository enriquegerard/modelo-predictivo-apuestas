# AWS Deployment Configuration
# Customiza estos valores antes de ejecutar aws_deploy.sh

# ============================================
# AWS CONFIGURATION
# ============================================
AWS_REGION=us-east-1
AWS_PROFILE=default  # Cambiar si tienes múltiples perfiles

# ============================================
# PROJECT SETTINGS
# ============================================
PROJECT_NAME=betting-analyzer
FUNCTION_NAME=daily-betting-analysis
LAMBDA_TIMEOUT=300          # segundos (máximo 900)
LAMBDA_MEMORY=512           # MB (128-10240)
PYTHON_RUNTIME=python3.11

# ============================================
# CRON SCHEDULE (UTC)
# ============================================
# Format: cron(minutes hours day month ? year)
# Examples:
#   cron(0 6 * * ? *)   = 06:00 AM UTC
#   cron(0 12 * * ? *)  = 12:00 PM UTC
#   cron(0 18 * * ? *)  = 06:00 PM UTC
CRON_EXPRESSION="cron(8 0 * * ? *)"  # 08:00 AM UTC (default)

# ============================================
# S3 BUCKET SETTINGS
# ============================================
BUCKET_VERSIONING=false     # true para mantener histórico
BUCKET_PUBLIC_ACCESS=true   # true para acceso público a reportes
BUCKET_EXPIRATION_DAYS=90   # Eliminar reportes tras N días (0 = nunca)

# ============================================
# LAMBDA LAYER CONFIGURATION
# ============================================
LAYER_NAME=betting-dependencies
LAYER_COMPATIBLE_RUNTIMES="python3.11"

# ============================================
# LOGGING & MONITORING
# ============================================
CLOUDWATCH_RETENTION_DAYS=7  # Retener logs X días (1,3,5,7,14,30,60,90,...)
ENABLE_X_RAY_TRACING=false   # Análisis de performance (costo adicional)

# ============================================
# OPCIONAL: NOTIFICACIONES POR EMAIL
# ============================================
ENABLE_SNS_NOTIFICATIONS=false
SNS_EMAIL=tu@email.com

# ============================================
# OPCIONAL: CUSTOM DOMAIN / STATIC SITE
# ============================================
# Cambiar a true si quieres generar un sitio estático con CloudFront
USE_CLOUDFRONT_CDN=false
CLOUDFRONT_DOMAIN=""

# ============================================
# TAGS (para organizar recursos)
# ============================================
TAG_ENVIRONMENT=production
TAG_TEAM=sports-analytics
TAG_COST_CENTER=personal
